pipeline {
agent anystages {stage('Build’) {
steps {
echo 'Building Website...’}
}stage('Test’) {
steps {
script {
if (fileExists('index.html')) {
echo 'Test Passed: index.html exists’
} else {
error 'Test Failed: index.html not found’}
}
}
}
